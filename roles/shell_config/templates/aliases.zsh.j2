# ─────────────────────────────────────────────────────────────────────────────
# ~/.aliases.zsh — Generated by Ansible
# ─────────────────────────────────────────────────────────────────────────────

# ── Navigation ────────────────────────────────────────────────────────────────
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias ~='cd ~'
alias -- -='cd -'

# ── Listing (lsd si disponible, sinon ls amélioré) ───────────────────────────
if command -v lsd &>/dev/null; then
  alias ls='lsd'
  alias l='lsd -l'
  alias la='lsd -la'
  alias lt='lsd --tree'
  alias lt2='lsd --tree --depth 2'
  alias lt3='lsd --tree --depth 3'
else
  alias ls='ls --color=auto'
  alias l='ls -lh'
  alias la='ls -lah'
fi
alias ll='l'
alias lld='l -d */'          # seulement les dossiers

# ── cat amélioré avec bat ─────────────────────────────────────────────────────
if command -v batcat &>/dev/null; then
  alias cat='batcat --paging=never'
  alias bat='batcat'
  alias batp='batcat'          # avec paging
elif command -v bat &>/dev/null; then
  alias cat='bat --paging=never'
fi

# ── grep amélioré ─────────────────────────────────────────────────────────────
if command -v rg &>/dev/null; then
  alias grep='rg'
else
  alias grep='grep --color=auto'
fi

# ── Système ───────────────────────────────────────────────────────────────────
alias cls='clear'
alias c='clear'
alias q='exit'
alias reload='source ~/.zshrc && echo "✅ .zshrc rechargé"'
alias zshrc='${EDITOR:-nano} ~/.zshrc'
alias aliases='${EDITOR:-nano} ~/.aliases.zsh'

# Espace disque
alias df='df -h'
alias du='du -h'
alias duh='du -sh *'
alias dus='du -sh * | sort -h'

# Mémoire
alias free='free -h'
alias mem='free -h'

# Processus
alias ps='ps auxf'
alias psg='ps aux | grep -v grep | grep -i'
alias top='htop'
alias kill9='kill -9'

# ── Réseau ────────────────────────────────────────────────────────────────────
alias ip='ip -c'                         # colorisé
alias myip='curl -s ifconfig.me && echo' # IP publique
alias localip="ip -4 addr | grep -oP '(?<=inet\s)\d+(\.\d+){3}' | grep -v 127"
alias ports='ss -tulnp'
alias listening='ss -tulnp'
alias pingcheck='ping -c 5 8.8.8.8'

# ── Git ───────────────────────────────────────────────────────────────────────
alias g='git'
alias gs='git status'
alias ga='git add'
alias gaa='git add --all'
alias gc='git commit'
alias gcm='git commit -m'
alias gca='git commit --amend'
alias gco='git checkout'
alias gcob='git checkout -b'
alias gp='git push'
alias gpf='git push --force-with-lease'
alias gpl='git pull'
alias gf='git fetch --all --prune'
alias gl='git log --oneline --graph --decorate --color'
alias gll='git log --graph --pretty=format:"%C(red)%h%Creset -%C(yellow)%d%Creset %s %C(green)(%ar) %C(bold blue)<%an>%Creset" --abbrev-commit'
alias gd='git diff'
alias gds='git diff --staged'
alias gst='git stash'
alias gstp='git stash pop'
alias gstl='git stash list'
alias greset='git reset --hard HEAD'
alias gclean='git clean -fd'
alias gbr='git branch -vv'
alias gbrd='git branch -d'
alias gbrD='git branch -D'

# ── Docker ────────────────────────────────────────────────────────────────────
alias d='docker'
alias dc='docker compose'
alias dcu='docker compose up -d'
alias dcd='docker compose down'
alias dcl='docker compose logs -f'
alias dcp='docker compose pull'
alias dcr='docker compose restart'
alias dps='docker ps'
alias dpsa='docker ps -a'
alias di='docker images'
alias dprune='docker system prune -af --volumes'
alias dexec='docker exec -it'
alias dlogs='docker logs -f'
alias dstop='docker stop $(docker ps -q)'    # stop tous les containers

# ── Kubernetes ────────────────────────────────────────────────────────────────
if command -v kubectl &>/dev/null; then
  alias k='kubectl'
  alias kg='kubectl get'
  alias kd='kubectl describe'
  alias kdel='kubectl delete'
  alias kaf='kubectl apply -f'
  alias kns='kubectl config set-context --current --namespace'
  alias kctx='kubectl config use-context'
  alias kgp='kubectl get pods'
  alias kgpa='kubectl get pods -A'
  alias kgs='kubectl get services'
  alias kgd='kubectl get deployments'
  alias klog='kubectl logs -f'
  alias kexec='kubectl exec -it'
fi

# ── Python / pip ──────────────────────────────────────────────────────────────
alias py='python3'
alias pip='pip3'
alias venv='python3 -m venv .venv && source .venv/bin/activate'
alias activate='source .venv/bin/activate'

# ── apt (Debian) ──────────────────────────────────────────────────────────────
alias apti='sudo apt install'
alias aptu='sudo apt update && sudo apt upgrade'
alias apts='apt search'
alias aptl='apt list --installed'
alias aptr='sudo apt remove'
alias aptc='sudo apt autoremove && sudo apt autoclean'

# ── Éditeur ───────────────────────────────────────────────────────────────────
alias v='${EDITOR:-nano}'
alias sv='sudo ${EDITOR:-nano}'

# ── Utilitaires ───────────────────────────────────────────────────────────────
alias h='history | tail -50'
alias hg='history | grep'
alias mkdir='mkdir -pv'
alias cp='cp -iv'
alias mv='mv -iv'
alias rm='rm -iv'
alias rmf='rm -rf'
alias ln='ln -sv'
alias wget='wget -c'                    # resume par défaut
alias curl='curl -L'                    # suit les redirections
alias path='echo $PATH | tr ":" "\n"'  # affiche le PATH lisiblement
alias now='date +"%Y-%m-%d %H:%M:%S"'
alias timestamp='date +%s'
alias week='date +%V'
alias weather='curl -s "wttr.in/{{ shell_user_home | regex_replace(".*/", "") }}?lang=fr&format=3" 2>/dev/null || curl -s wttr.in/?format=3'
alias wttr='curl -s wttr.in/?lang=fr'
alias pubip='curl -s ifconfig.me && echo'

# ── Sécurité / Sudo ───────────────────────────────────────────────────────────
alias please='sudo'
alias sudoedit='sudo -e'

# ── Raccourcis divers ────────────────────────────────────────────────────────
alias serve='python3 -m http.server 8000'  # serveur HTTP rapide
alias ports-check='nmap -sT -O localhost'
alias mypath='readlink -f'
alias extract='_extract'  # fonction définie dans functions.zsh
