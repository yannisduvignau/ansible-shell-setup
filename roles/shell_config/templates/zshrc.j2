# ─────────────────────────────────────────────────────────────────────────────
# .zshrc — Generated by Ansible
# ─────────────────────────────────────────────────────────────────────────────

# ── Powerlevel10k instant prompt (doit être en PREMIER) ───────────────────────
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# ── Oh My Zsh ─────────────────────────────────────────────────────────────────
export ZSH="{{ omz_install_dir }}"
ZSH_THEME="{{ omz_theme }}"

# Mise à jour automatique silencieuse
zstyle ':omz:update' mode auto
zstyle ':omz:update' frequency 7

# Plugins
plugins=({{ omz_plugins | join(' ') }})

source "$ZSH/oh-my-zsh.sh"

# ── Variables d'environnement ─────────────────────────────────────────────────
[[ -f ${ZDOTDIR:-$HOME}/.exports.zsh ]] && source ${ZDOTDIR:-$HOME}/.exports.zsh

# ── Aliases ───────────────────────────────────────────────────────────────────
[[ -f ${ZDOTDIR:-$HOME}/.aliases.zsh ]] && source ${ZDOTDIR:-$HOME}/.aliases.zsh

# ── Fonctions ─────────────────────────────────────────────────────────────────
[[ -f ${ZDOTDIR:-$HOME}/.functions.zsh ]] && source ${ZDOTDIR:-$HOME}/.functions.zsh

# ── Atuin (historique amélioré) ───────────────────────────────────────────────
if command -v atuin &>/dev/null; then
  eval "$(atuin init zsh)"
fi

# ── FZF ───────────────────────────────────────────────────────────────────────
if [[ -f /usr/share/doc/fzf/examples/key-bindings.zsh ]]; then
  source /usr/share/doc/fzf/examples/key-bindings.zsh
fi
if [[ -f /usr/share/doc/fzf/examples/completion.zsh ]]; then
  source /usr/share/doc/fzf/examples/completion.zsh
fi

export FZF_DEFAULT_OPTS="
  --height=60%
  --layout=reverse
  --border=rounded
  --color=fg:#cdd6f4,bg:#1e1e2e,hl:#89b4fa
  --color=fg+:#cdd6f4,bg+:#313244,hl+:#89b4fa
  --color=info:#cba6f7,prompt:#89dceb,pointer:#f5c2e7
  --color=marker:#a6e3a1,spinner:#f5c2e7,header:#89b4fa
  --preview-window=border-rounded
"
export FZF_DEFAULT_COMMAND='find . -type f 2>/dev/null'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"

# ── Powerlevel10k config ───────────────────────────────────────────────────────
[[ -f ${ZDOTDIR:-$HOME}/.p10k.zsh ]] && source ${ZDOTDIR:-$HOME}/.p10k.zsh

# ── Options zsh supplémentaires ───────────────────────────────────────────────
setopt AUTO_CD              # cd sans taper cd
setopt CORRECT              # correction automatique des typos
setopt HIST_IGNORE_DUPS     # pas de doublons dans l'historique
setopt HIST_IGNORE_SPACE    # commandes précédées d'un espace = non enregistrées
setopt SHARE_HISTORY        # historique partagé entre les sessions
setopt EXTENDED_HISTORY     # timestamp dans l'historique
HISTSIZE=100000
SAVEHIST=100000

# ── Complétion améliorée ──────────────────────────────────────────────────────
autoload -Uz compinit && compinit
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Z}'
zstyle ':completion:*:descriptions' format '%F{yellow}-- %d --%f'