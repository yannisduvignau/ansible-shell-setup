## Atuin configuration — generated by Ansible

## Comportement de la recherche
## filter_mode = "global" | "host" | "session" | "directory"
filter_mode = "global"
filter_mode_shell_up_key_binding = "session"

## Affichage
style = "compact"
show_preview = true
max_preview_height = 4

## Raccourcis
## Ctrl+R pour la recherche interactive
## Flèche haut pour la recherche par session (configurable)
keymap_mode = "emacs"

## Historique
history_filter = [
  "^ls$",
  "^cd$",
  "^pwd$",
  "^ ",       # commandes commençant par un espace (mode secret)
]

## Sync (décommentez et configurez si vous utilisez atuin.sh cloud)
# sync_address = "https://api.atuin.sh"
# sync_frequency = "10m"
## auto_sync = true
