# ─────────────────────────────────────────────────────────────────────────────
# ~/.exports.zsh — Generated by Ansible
# ─────────────────────────────────────────────────────────────────────────────

# ── Éditeur par défaut ────────────────────────────────────────────────────────
export EDITOR='nano'
export VISUAL='nano'

# ── Langue ────────────────────────────────────────────────────────────────────
export LANG='fr_FR.UTF-8'
export LC_ALL='fr_FR.UTF-8'

# ── Pager (less amélioré) ────────────────────────────────────────────────────
export PAGER='less'
export LESS='-R --use-color -Dd+r$Du+b'
export MANPAGER='less -R --use-color -Dd+r -Du+b'

# ── PATH enrichi ──────────────────────────────────────────────────────────────
export PATH="$HOME/.local/bin:$HOME/.cargo/bin:$HOME/go/bin:$PATH"

# ── bat (si installé comme batcat sur Debian) ────────────────────────────────
if command -v batcat &>/dev/null && ! command -v bat &>/dev/null; then
  export BAT_THEME='Catppuccin-mocha'
  mkdir -p ~/.local/bin
  ln -sf "$(which batcat)" ~/.local/bin/bat 2>/dev/null || true
fi

# ── FZF ───────────────────────────────────────────────────────────────────────
export FZF_COMPLETION_TRIGGER='**'

# ── Historique zsh ────────────────────────────────────────────────────────────
export HISTFILE="$HOME/.zsh_history"
export HISTSIZE=100000
export SAVEHIST=100000

# ── GPG ───────────────────────────────────────────────────────────────────────
export GPG_TTY=$(tty)

# ── Python ────────────────────────────────────────────────────────────────────
export PYTHONDONTWRITEBYTECODE=1
export PYTHONUNBUFFERED=1

# ── Go ────────────────────────────────────────────────────────────────────────
# export GOPATH="$HOME/go"

# ── Rust ──────────────────────────────────────────────────────────────────────
# [[ -f "$HOME/.cargo/env" ]] && source "$HOME/.cargo/env"

# ── Couleurs ls ───────────────────────────────────────────────────────────────
export LS_COLORS='rs=0:di=01;34:ln=01;36:pi=40;33:so=01;35:do=01;35:bd=40;33;01:cd=40;33;01:or=40;31;01:mi=00:su=37;41:sg=30;43:ca=30;41:tw=30;42:ow=34;42:st=37;44:ex=01;32'

# ── Less colors ───────────────────────────────────────────────────────────────
export LESS_TERMCAP_mb=$'\e[1;31m'
export LESS_TERMCAP_md=$'\e[1;36m'
export LESS_TERMCAP_me=$'\e[0m'
export LESS_TERMCAP_so=$'\e[01;33m'
export LESS_TERMCAP_se=$'\e[0m'
export LESS_TERMCAP_us=$'\e[1;32m'
export LESS_TERMCAP_ue=$'\e[0m'
