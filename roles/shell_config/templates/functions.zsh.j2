# ── Extraction universelle d'archives ────────────────────────────────────────
_extract() {
  if [[ -f "$1" ]]; then
    case "$1" in
      *.tar.bz2)   tar xjf "$1"     ;;
      *.tar.gz)    tar xzf "$1"     ;;
      *.tar.xz)    tar xJf "$1"     ;;
      *.bz2)       bunzip2 "$1"     ;;
      *.rar)       unrar e "$1"     ;;
      *.gz)        gunzip "$1"      ;;
      *.tar)       tar xf "$1"      ;;
      *.tbz2)      tar xjf "$1"     ;;
      *.tgz)       tar xzf "$1"     ;;
      *.zip)       unzip "$1"       ;;
      *.Z)         uncompress "$1"  ;;
      *.7z)        7z x "$1"        ;;
      *)           echo "'$1' : format non supporté" ;;
    esac
  else
    echo "'$1' n'est pas un fichier valide"
  fi
}

# ── Créer un dossier et y entrer directement ─────────────────────────────────
mkcd() {
  mkdir -p "$1" && cd "$1"
}

# ── Chercher dans l'historique ────────────────────────────────────────────────
hf() {
  history | grep -i "$1"
}

# ── Trouver un processus par nom ─────────────────────────────────────────────
psf() {
  ps aux | grep -v grep | grep -i "$1"
}

# ── Tuer un processus par nom ─────────────────────────────────────────────────
killp() {
  local pid
  pid=$(ps aux | grep -v grep | grep -i "$1" | awk '{print $2}')
  if [[ -n "$pid" ]]; then
    echo "Kill PID: $pid"
    kill -9 $pid
  else
    echo "Aucun processus trouvé pour : $1"
  fi
}

# ── Port scan rapide ──────────────────────────────────────────────────────────
port() {
  if [[ -n "$1" ]]; then
    echo "Vérification du port $1..."
    if ss -tulnp | grep -q ":$1 "; then
      echo "✅ Port $1 est en écoute"
      ss -tulnp | grep ":$1 "
    else
      echo "❌ Port $1 n'est pas en écoute"
    fi
  else
    echo "Usage: port <numéro>"
  fi
}

# ── Infos réseau rapides ──────────────────────────────────────────────────────
netinfo() {
  echo "─── Interfaces réseau ───────────────────────────────"
  ip -4 addr show | grep -E "(^[0-9]+:|inet )" | \
    awk '/^[0-9]/{iface=$2} /inet /{printf "  %-15s %s\n", iface, $2}'
  echo ""
  echo "─── Route par défaut ────────────────────────────────"
  ip route | grep default
  echo ""
  echo "─── IP publique ─────────────────────────────────────"
  echo "  $(curl -s --max-time 3 ifconfig.me 2>/dev/null || echo 'N/A')"
  echo "──────────────────────────────────────────────────────"
}

# ── Backup rapide d'un fichier ────────────────────────────────────────────────
bak() {
  cp "$1" "$1.bak.$(date +%Y%m%d_%H%M%S)"
  echo "✅ Sauvegarde créée : $1.bak.$(date +%Y%m%d_%H%M%S)"
}

# ── Afficher les fichiers les plus volumineux ────────────────────────────────
bigfiles() {
  local count="${1:-10}"
  du -ah . 2>/dev/null | sort -rh | head -n "$count"
}

# ── Chercher un fichier récursivement ────────────────────────────────────────
ff() {
  find . -name "*$1*" -not -path "*/.git/*" 2>/dev/null
}

# ── Chercher dans les fichiers ────────────────────────────────────────────────
fg() {
  if command -v rg &>/dev/null; then
    rg -i "$@"
  else
    grep -ri "$@" .
  fi
}

# ── Générer un mot de passe aléatoire ────────────────────────────────────────
genpass() {
  local len="${1:-20}"
  tr -dc 'A-Za-z0-9!@#$%^&*' < /dev/urandom | head -c "$len" && echo
}

# ── Encoder/Décoder base64 ───────────────────────────────────────────────────
b64enc() { echo -n "$1" | base64; }
b64dec() { echo -n "$1" | base64 -d; }

# ── Calculer le hash d'un fichier ────────────────────────────────────────────
sha() {
  local algo="${2:-256}"
  sha${algo}sum "$1"
}

# ── Surveiller un fichier de log ─────────────────────────────────────────────
log() {
  tail -f "${1:-/var/log/syslog}"
}

# ── Résumé rapide du système ─────────────────────────────────────────────────
sysinfo() {
  echo "─── Système ─────────────────────────────────────────"
  echo "  OS      : $(cat /etc/os-release | grep PRETTY_NAME | cut -d= -f2 | tr -d '"')"
  echo "  Kernel  : $(uname -r)"
  echo "  Uptime  : $(uptime -p)"
  echo "  CPU     : $(nproc) cœurs — $(top -bn1 | grep 'Cpu(s)' | awk '{print $2}')% utilisé"
  echo "  RAM     : $(free -h | awk '/^Mem:/{print $3 " / " $2}')"
  echo "  Disque  : $(df -h / | awk 'NR==2{print $3 " / " $2 " (" $5 " utilisé)"}')"
  echo ""
  netinfo
}

# ── cd + ls automatiquement ──────────────────────────────────────────────────
cd() {
  builtin cd "$@" && ls
}

# ── Afficher la météo locale ─────────────────────────────────────────────────
meteo() {
  local city="${1:-}"
  curl -s "wttr.in/${city}?lang=fr"
}

# ── Créer un fichier temporaire et l'éditer ──────────────────────────────────
tmp() {
  local f
  f=$(mktemp /tmp/tmp.XXXXXX.${1:-txt})
  ${EDITOR:-nano} "$f"
  echo "Fichier : $f"
}

# ── Copier dans le clipboard (si xclip disponible) ───────────────────────────
copy() {
  if command -v xclip &>/dev/null; then
    echo -n "$1" | xclip -selection clipboard
    echo "✅ Copié dans le presse-papiers"
  elif command -v xsel &>/dev/null; then
    echo -n "$1" | xsel --clipboard --input
    echo "✅ Copié dans le presse-papiers"
  else
    echo "xclip ou xsel non installé"
  fi
}
